{
  "name": "internetsosplay",
  "version": "1.0.0",
  "description": "InternetSOSplay — Reconexion automatica para portales cautivos y uso de emergencia",
  "main": "main.js",
  "author": "OfertivaMX",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LewisNoN/internetsosplay-app.git"
  },
  "scripts": {
    "start": "electron .",
    "electron": "electron .",
    "generar-licencia": "node tools/license-generator.js",
    "generate-keys": "node tools/generate-keys.js",
    "build": "electron-builder --win",
    "build:installer": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "http-server": "^14.1.1"
  },
  "build": {
    "appId": "com.ofertivamx.internetsosplay",
    "productName": "InternetSOSplay",
    "artifactName": "InternetSOSplay-${version}-${arch}.${ext}",
    "asar": true,
    "compression": "maximum",
    "copyright": "Copyright © 2024 OfertivaMX",
    "directories": {
      "output": "dist-v31"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "renderer/**/*",
      "scripts/**/*",
      "assets/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "LewisNoN",
        "repo": "InternetSoSplay-app"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "artifactName": "InternetSOSplay-Setup-${version}.exe",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "InternetSOSplay",
      "include": "assets/installer.nsh"
    },
    "asarUnpack": [
      "renderer/*.mp4"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-machine-id": "^1.1.12"
  }
}
